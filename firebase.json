{
  "apphosting": {
    "backendId": "bocaditos",
    "rootDir": "/",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "functions",
      ".next"
    ]
  },
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "bocaditos",
          "region": "us-central1",
          "pinTag": true
        }
      }
    ]
  }
}
